<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="de.rufzeichensucher.ui.StatisticsWindowController"
           minWidth="720" minHeight="540">

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">

        <!-- Tab 1: Übersicht -->
        <Tab text="Übersicht">
            <ScrollPane fitToWidth="true">
                <GridPane fx:id="overviewGrid" hgap="14" vgap="14">
                    <padding><Insets topRightBottomLeft="20"/></padding>
                </GridPane>
            </ScrollPane>
        </Tab>

        <!-- Tab 2: Lizenzklassen -->
        <Tab text="Lizenzklassen">
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <VBox fx:id="licenseBox" spacing="16" alignment="CENTER" fillWidth="true">
                    <padding><Insets topRightBottomLeft="20"/></padding>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Tab 3: Bundesländer -->
        <Tab text="Bundesländer">
            <SplitPane orientation="VERTICAL" dividerPositions="0.48">
                <StackPane fx:id="stateChartPane" minHeight="240"/>
                <TableView fx:id="stateTable" editable="false">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="stateNameCol"   text="Bundesland"   prefWidth="220"/>
                        <TableColumn fx:id="stateCountCol"  text="Anzahl"        prefWidth="90"/>
                        <TableColumn fx:id="statePerCapCol" text="je 10.000 EW"  prefWidth="130"/>
                    </columns>
                </TableView>
            </SplitPane>
        </Tab>

        <!-- Tab 4: Präfixe -->
        <Tab text="Präfixe">
            <ScrollPane fitToWidth="true">
                <VBox fx:id="prefixBox" spacing="0">
                    <padding><Insets topRightBottomLeft="20"/></padding>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Tab 5: Duplikate -->
        <Tab text="Duplikate">
            <BorderPane fx:id="dupPane"/>
        </Tab>

        <!-- Tab 6: Heatmap -->
        <Tab text="Heatmap">
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <StackPane fx:id="heatmapPane"/>
            </ScrollPane>
        </Tab>

    </TabPane>

    <!-- Computing overlay -->
    <StackPane fx:id="computingPane" visible="false" mouseTransparent="false"
               style="-fx-background-color: rgba(0,0,0,0.45);">
        <VBox spacing="12" alignment="CENTER" styleClass="loading-card" maxWidth="300">
            <ProgressIndicator maxWidth="44" maxHeight="44"/>
            <Label text="Statistiken werden berechnet …" styleClass="loading-status"/>
        </VBox>
    </StackPane>

</StackPane>

                                        <argument>--linux-menu-group</argument><argument>Network</argument>
                                        <argument>--dest</argument>          <argument>${project.build.directory}/dist</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>

    </profiles>

</project>